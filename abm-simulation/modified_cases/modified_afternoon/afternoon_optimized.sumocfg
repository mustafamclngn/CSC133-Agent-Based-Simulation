<?xml version="1.0" encoding="UTF-8"?>
<configuration xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/sumoConfiguration.xsd">
    <input>
        <net-file value="optimized_initial8_network.net.xml"/>
        <route-files value="routes_afternoon.rou.xml"/>
        <additional-files value="detectors.add.xml"/>
    </input>
    
    <output>
        <tripinfo-output value="outputs_afternoon/tripinfo.xml"/>
        <edgedata-output value="outputs_afternoon/edge_data.xml"/>
    </output>

    <time>
        <begin value="0"/>
        <end value="3600"/>
    </time>
    
    <gui_only>
        <start value="true"/>
    </gui_only>
</configuration>